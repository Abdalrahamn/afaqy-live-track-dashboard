#!/bin/sh

echo "Running pre-commit checks..."

echo ""
echo "[1/3] Running ESLint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "ESLint failed. Please fix the errors before committing."
  exit 1
fi

echo ""
echo "[2/3] Running Prettier check..."
npm run format:check
if [ $? -ne 0 ]; then
  echo "Prettier check failed. Run 'npm run format:fix' to fix formatting issues."
  exit 1
fi

echo ""
echo "[3/3] Running tests..."
npm test
if [ $? -ne 0 ]; then
  echo "Tests failed. Please fix the failing tests before committing."
  exit 1
fi

echo ""
echo "All pre-commit checks passed!"
